{
	"name": "additional-subscriptions-analytics",
	"version": "0.1.0-dev",
	"description": "Native WooCommerce Analytics reports backed by subscription analytics lookup tables.",
	"private": true,
	"engines": {
		"node": ">=20.11.1 <21",
		"npm": ">=10"
	},
	"scripts": {
		"build": "wp-scripts build",
		"env": "wp-env",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"start": "wp-scripts start",
		"lint": "npm run lint:js && npm run lint:php",
		"lint:js": "wp-scripts lint-js client",
		"lint:php": "composer lint",
		"test:integration:wp-env": "wp-env run --env-cwd='wp-content/plugins/additional-subscriptions-analytics' tests-cli vendor/bin/phpunit --testsuite integration",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.0",
		"@woocommerce/dependency-extraction-webpack-plugin": "^3.1.0",
		"@wordpress/env": "^11.8.1",
		"@wordpress/scripts": "^31.8.0"
	},
	"overrides": {
		"sass": "1.99.0"
	}
}
